{
  "name": "console-dashboard",
  "version": "1.0.0",
  "description": "this is a console dashboard for redbiller",
  "license": "ISC",
  "author": "goziri",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "test": "node --test",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:push": "npx drizzle-kit push",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:introspect": "npx drizzle-kit introspect",
    "db:check": "npx drizzle-kit check",
    "migrate:auth-rbac": "node scripts/run-auth-rbac-migration.js",
    "migrate:biller-id": "node scripts/run-biller-id-migration.js",
    "migrate:mfa-security": "node scripts/run-mfa-security-migration.js",
    "migrate:crosslink-only-users": "node scripts/run-crosslink-only-users-migration.js",
    "migrate:pricing-permissions": "node scripts/run-pricing-permissions-migration.js",
    "migrate:baas-pricing": "node scripts/run-baas-pricing-migration.js",
    "setup:mfa-key": "node scripts/setup-mfa-key.js",
    "inspect:user-rbac": "node scripts/inspect-user-rbac.js",
    "set:user-management-only": "node scripts/set-user-management-only.js",
    "decrypt:env": "node scripts/decrypt-env-value.js",
    "decrypt": "node scripts/decrypt-env-value.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "axios": "^1.13.4",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "mysql2": "^3.16.3",
    "otplib": "^13.4.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.9",
    "nodemon": "^3.1.11",
    "pino-pretty": "^13.1.3"
  }
}

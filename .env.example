PORT=5000
NODE_ENV=development
DB_MODE=local

# Local DB settings
DB_NAME=console-dashboard
# Separate database containing Users, RBAC, MFA, and auth sessions.
AUTH_DB_NAME=console
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DIALECT=mysql

# Auth
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=24h
JWT_ISSUER=sterllo-console
JWT_AUDIENCE=sterllo-dashboard

# MFA / single-device sessions
# Generate a 32-byte base64 key: openssl rand -base64 32
# Never commit the real value or reuse JWT_SECRET.
MFA_ENCRYPTION_KEY=
MFA_ISSUER=Sterllo Console
MFA_CHALLENGE_TTL_SECONDS=300
MFA_MAX_ATTEMPTS=5
MFA_TOTP_TOLERANCE_SECONDS=30
MFA_RECOVERY_CODE_COUNT=10
AUTH_SESSION_TTL_HOURS=24
MFA_RECENT_WINDOW_MINUTES=10

# Production encrypted DB values (only required when DB_MODE=production)
# Ciphertext values (base64)
INF_STERLLO_CONSOLE_DATABASE_HOST_KEYCHAIN=
INF_STERLLO_CONSOLE_DATABASE_USERNAME_KEYCHAIN=
INF_STERLLO_CONSOLE_DATABASE_PASSWORD_KEYCHAIN=
INF_STERLLO_CONSOLE_DATABASE_NAME_KEYCHAIN=

# Keychain values used to derive key/iv
DB_HOST_KEY=
DB_USERNAME_KEY=
DB_PASSWORD_KEY=
DB_NAME_KEY=

# AES decrypt rule:
# key = first 32 chars of keychain
# iv = last 16 chars of keychain

# Beamer / ISVS (account-link & account-update proxy)
# SOURCE_PRODUCT_KEY + SOURCE_PRODUCT_KEYCHAIN (or SOURCE_PRODUCT_KEY_KEYCHAIN)
# TARGET_PRODUCT_KEY + TARGET_PRODUCT_KEYCHAIN (or TARGET_PRODUCT_KEY_KEYCHAIN)
# ISVS response bodies `{ "response": "<base64>" }` decrypt with the decrypted TARGET product key.
# BEAMER_ISVS_WIRE_FORMAT=credentials  (default — plain headers/body; encrypt Credentials only)
# BEAMER_ISVS_WIRE_FORMAT=headers       (encrypt User-Key/Accout-Key/Request-Id)
# BEAMER_ISVS_WIRE_FORMAT=object     (encrypted headers blob + IV; only if ISVS confirms)
# BEAMER_ISVS_ENCRYPT_KEY=target     (default — AES uses decrypted target product key)
# BEAMER_ISVS_ENCRYPT_KEY=target-keychain | source | source-keychain
# BEAMER_ISVS_DEBUG=true             (log outbound audit on every link/update call)

# `npm run decrypt -- "<ciphertext>"` — if that exact string is already in one of the INF_* / DB_* ciphertext
# vars above, the script picks the matching keychain. Otherwise set DECRYPT_KEYCHAIN=... or pass keychain as 2nd arg.
# DECRYPT_KEYCHAIN=
